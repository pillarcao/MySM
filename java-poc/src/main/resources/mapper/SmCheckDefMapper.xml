<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.sm.mapper.SmCheckDefMapper">
    <resultMap id="BaseResultMap" type="com.sm.entity.SmCheckDef">
        <id column="ID" property="id"/>
        <result column="TABLE_ID" property="tableId"/>
        <result column="CHECK_TYPE" property="checkType"/>
        <result column="CHECK_ORDER" property="checkOrder"/>
        <result column="CHECK_KIND" property="checkKind"/>
        <result column="FIELD_NAME" property="fieldName"/>
        <result column="REF_TABLE" property="refTable"/>
        <result column="REF_FIELD" property="refField"/>
        <result column="EXPECT_VALUE" property="expectValue"/>
        <result column="ERR_MSG" property="errMsg"/>
    </resultMap>

    <select id="findByTableIdAndCheckType" resultMap="BaseResultMap">
        SELECT * FROM SM_CHECK_DEF WHERE TABLE_ID = #{tableId} AND CHECK_TYPE = #{checkType} ORDER BY CHECK_ORDER
    </select>
</mapper>
